      "stage": 3,
      "speaker": "Player",
      "name": "루",
      "text": "...MS엔터가 보인다.",
      "position": "Left",
      "nextDialogueId": "3-2_11"
    },
    {
      "id": "3-2_11",
      "stage": 3,
      "speaker": "Player",
